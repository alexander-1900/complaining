# --- SERVER CONFIGURATION ---
PORT=3000
NODE_ENV=development
# --- DATABASE CONFIGURATION (PostgreSQL) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=aflou_complaints
DB_USER=postgres
DB_PASSWORD=1900
DB_LOGGING=false

# --- SEQUELIZE POOLING (High Concurrency: 1000 users) ---
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=60000
DB_POOL_IDLE=10000

# --- REDIS CONFIGURATION (Caching & Rate Limiting) ---
REDIS_URL=redis://127.0.0.1:6379
REDIS_PASSWORD=

# --- SECURITY & AUTHENTICATION ---
# Generate using: openssl rand -base64 64
JWT_SECRET=super_secret_aflou_token_key_2026
JWT_EXPIRES_IN=1h

# --- ADMIN ACCESS CONTROL ---
# Comma-separated list of allowed IP addresses for Governor/Secretary panels
ADMIN_IP_WHITELIST=127.0.0.1,::1

# --- FILE UPLOAD SETTINGS ---
UPLOAD_PATH=./storage/attachments
MAX_FILE_SIZE=5242880 # 5MB in bytes
ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf

# --- SESSION CONFIGURATION ---
SESSION_SECRET=super_secret_aflou_token_key_20
